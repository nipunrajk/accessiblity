{
  "name": "fastfix-backend",
  "version": "1.0.0",
  "description": "Backend service for FastFix website analyzer",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install-deps": "npm install",
    "lint:fix": "eslint . --fix",
    "precommit": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "**/*.js": [
      "eslint --fix",
      "prettier --write",
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/openai": "^1.5.3",
    "@octokit/rest": "^22.0.1",
    "axe-puppeteer": "^1.1.1",
    "axios": "^1.18.1",
    "chrome-launcher": "^1.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "groq-sdk": "^1.3.0",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.4.0",
    "pa11y": "^9.1.1",
    "puppeteer": "^25.2.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.5",
    "supertest": "^7.2.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
